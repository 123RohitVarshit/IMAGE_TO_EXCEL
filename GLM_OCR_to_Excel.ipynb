        "\n",
        "# Step 1 — GLM-OCR → Markdown\n",
        "print(\"[1/3] Running GLM-OCR table recognition...\")\n",
        "md_table = extract_table_markdown(image_path)\n",
        "print(\"\\n── Raw Markdown output ──\")\n",
        "print(md_table)\n",
        "display(Markdown(md_table))\n",
        "\n",
        "# Step 2 — Markdown → HTML\n",
        "print(\"\\n[2/3] Converting Markdown → HTML...\")\n",
        "html_table = md_lib.markdown(md_table, extensions=[\"tables\"])\n",
        "display(HTML(html_table))\n",
        "\n",
        "# Step 3 — HTML → Excel\n",
        "print(f\"\\n[3/3] Generating Excel file: {output_filename}...\")\n",
        "html_to_excel(html_table, output_filename, sheet_name=Path(image_path).stem)\n",
        "print(f\"\\n✅ Done! File saved as: {output_filename}\")"
